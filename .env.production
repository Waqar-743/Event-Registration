# Production Environment Variables for Render
# Copy these to Render Dashboard > Environment Variables

# Database
DATABASE_PATH=/app/data/events.db

# Server
HOST=0.0.0.0
PORT=10000

# CORS - Update with your actual frontend URL after deployment
# Example: ALLOWED_ORIGINS=https://event-registration-frontend.onrender.com
ALLOWED_ORIGINS=https://event-registration-frontend.onrender.com

# Python
PYTHON_VERSION=3.11.9
